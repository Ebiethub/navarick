# Canonical production URL used by metadata, sitemap, robots, and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Public contact address shown in the site footer.
NEXT_PUBLIC_CONTACT_EMAIL=hello@your-production-domain.com

# Contact form delivery.
CONTACT_EMAIL_PROVIDER=resend
CONTACT_EMAIL_TO=hello@your-production-domain.com
CONTACT_EMAIL_FROM="NAVARICK <hello@your-production-domain.com>"

# Resend API key. Never commit a real key.
RESEND_API_KEY=

# Optional analytics and verification. Leave blank until approved.
GOOGLE_ANALYTICS_ID=
GOOGLE_SITE_VERIFICATION=
MICROSOFT_CLARITY_ID=
PLAUSIBLE_DOMAIN=
